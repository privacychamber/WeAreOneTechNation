# Basic SPA Routing
RewriteEngine On

# 1. Force SSL
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. Stop if file or directory exists (including /api/...)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3. Everything else to index.html
RewriteRule . index.html [L]

# Security
Options -Indexes
